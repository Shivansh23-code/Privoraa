# Copy to .env and fill in real values. docker-compose and run-local.ps1 read .env automatically.
# NEVER commit a real .env — it is gitignored. Keep secrets out of this example file.

# OpenRouter — server-side ONLY. Without it, /models serves a static fallback
# and chat returns a friendly "not configured" error. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Public URL of the frontend (sent to OpenRouter as attribution header).
APP_PUBLIC_URL=http://localhost:5173
APP_TITLE=Privoraa

# Security — MUST be a long random string (>= 32 bytes) in production.
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# CORS — comma-separated allowed origins (your Vercel app + local dev).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://privoraa.vercel.app

# Database. For docker-compose these are overridden to point at the mysql service.
DB_USER=root
DB_PASS=Shivansh@123
# Cache: "simple" (in-memory, no Redis) for local dev, "redis" when Redis is available.
CACHE_TYPE=simple

# Redis (only used when CACHE_TYPE=redis).
REDIS_HOST=localhost
REDIS_PORT=6379

# RAG embeddings — OpenRouter embedding model slug. Blank uses the built-in
# deterministic local embedding (no external calls).
EMBEDDING_MODEL=

# Per-user rate limits (kept at/under OpenRouter free-tier limits).
RATE_LIMIT_PER_MIN=20
RATE_LIMIT_PER_DAY=200
