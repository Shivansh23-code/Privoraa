# Frontend environment (Vite). Copy to `.env` and adjust.
#
# Base URL of the Privoraa Spring Boot backend (must include /api/v1).
# - Local dev:   http://localhost:8099/api/v1
# - Production:  https://privoraa-backend.onrender.com/api/v1
#
# If unset, the app auto-selects: the hosted backend when served from a real
# domain, localhost otherwise. Set this explicitly in Vercel to be safe.
# When the backend is unreachable, the UI falls back to a local demo engine.
VITE_API_BASE_URL=http://localhost:8099/api/v1
